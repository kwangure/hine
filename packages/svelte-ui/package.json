{
	"name": "@hinejs/svelte-ui",
	"version": "0.0.0",
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"format": "wireit",
		"package": "wireit",
		"publint": "wireit",
		"sync": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"./svelte-kit/output",
				"build"
			]
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!types/**",
				"!dist/**",
				"!.svelte-kit/**",
				".prettierignore",
				"prettier.config.js"
			],
			"output": []
		},
		"check": {
			"command": "svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"sync"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"package"
			],
			"files": [
				"dist/**",
				"LICENSE",
				"README.md"
			],
			"output": [
				"*.tgz"
			]
		},
		"package": {
			"clean": "if-file-deleted",
			"command": "svelte-package -i ./src/lib",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"svelte.config.js",
				"tsconfig.json"
			],
			"output": [
				"dist"
			]
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"publint",
				"sync"
			]
		},
		"publint": {
			"command": "publint",
			"files": [
				"dist",
				"package.json"
			],
			"output": []
		},
		"sync": {
			"command": "svelte-kit sync",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js",
				"tsconfig.json"
			],
			"output": []
		}
	},
	"exports": {
		"./components": {
			"types": "./dist/components/index.d.ts",
			"svelte": "./src/lib/components/index.js",
			"default": "./src/lib/components/index.js"
		},
		"./dom": {
			"types": "./dist/dom/dom.d.ts",
			"default": "./src/lib/dom/dom.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"src/lib",
		"!src/lib/**/*.test.*",
		"!src/lib/**/*.spec.*"
	],
	"dependencies": {
		"@mdi/js": "^7.2.96"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^1.20.4",
		"svelte": "^4.0.0"
	},
	"devDependencies": {
		"@hinejs/prettier": "*",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/kit": "^1.20.4",
		"@sveltejs/package": "^2.0.0",
		"autoprefixer": "^10.4.14",
		"postcss": "^8.4.27",
		"prettier": "^3.0.2",
		"prettier-plugin-svelte": "^3.0.3",
		"prettier-plugin-tailwindcss": "^0.5.3",
		"publint": "^0.1.9",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.4.2"
	},
	"license": "MIT",
	"type": "module"
}
