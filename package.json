{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*",
		"sites/*"
	],
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"pre-commit": "wireit",
		"release": "wireit",
		"test": "wireit",
		"version": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"cross-env": "^7.0.3",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"unified": "^11.0.2",
		"unist-util-visit": "^5.0.0",
		"wireit": "^0.14.1"
	},
	"wireit": {
		"build": {
			"dependencies": [
				"build:packages",
				"build:readme",
				"build:sites"
			]
		},
		"build:packages": {
			"dependencies": [
				"./packages/hine:build"
			]
		},
		"build:sites": {
			"dependencies": [
				"./sites/hine.dev:build"
			]
		},
		"build:readme": {
			"clean": false,
			"command": "node ./scripts/build-readme.js",
			"files": [
				"README_TEMPLATE.md",
				"examples/**/*.js"
			],
			"output": [
				"README.md"
			]
		},
		"check": {
			"dependencies": [
				"./examples/basic:build",
				"./sites/hine.dev:check"
			]
		},
		"dev": {
			"dependencies": [
				"./sites/hine.dev:dev"
			]
		},
		"format": {
			"command": "prettier . --write --cache --config ./config/prettier.config.mjs --ignore-path ./config/.prettierignore",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!packages/*/dist/**",
				"!packages/*/types/**",
				"./config/prettier.config.mjs",
				"./config/.prettierignore"
			],
			"output": []
		},
		"lint": {
			"command": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint --color --cache --fix --config ./config/eslint.config.js --cache-location ./config/.eslintcache \"**/*.{js,svelte}\"",
			"files": [
				"**/*.{js,svelte}",
				"!packages/*/dist/**",
				"!packages/*/types/**",
				"./config/eslint.config.js"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"build:readme",
				"./examples/basic:pre-commit",
				"./packages/hine:pre-commit",
				"./sites/hine.dev:pre-commit"
			]
		},
		"release": {
			"command": "npx changeset publish",
			"dependencies": [
				"./packages/hine:release"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test"
			]
		},
		"version": {
			"#comment": [
				"Changesets doesn't bump package-lock.json so we run `pnpm install`",
				"to do it for us"
			],
			"command": "changeset version && pnpm install",
			"files": [
				"./changeset/*.md",
				"./packages/**/package.json",
				"./packages/**/CHANGELOG.md"
			]
		}
	},
	"#comment": [
		"Rollup override fixes Vercel missng module error.",
		"See https://github.com/rollup/rollup/issues/5194"
	],
	"pnpm": {
		"overrides": {
			"rollup": "npm:@rollup/wasm-node"
		}
	}
}
