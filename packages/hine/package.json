{
	"name": "hine",
	"version": "0.0.12",
	"description": "A state machine library",
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"publint": "wireit",
		"release": "release-it",
		"test": "wireit"
	},
	"keywords": [
		"state",
		"machine",
		"state-machine",
		"svelte",
		"react"
	],
	"license": "MIT",
	"files": [
		"dist",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"devDependencies": {
		"@sveltejs/package": "^2.0.2",
		"publint": "^0.1.11",
		"release-it": "^15.6.0",
		"type-fest": "^3.6.1",
		"typescript": "^5.0.3",
		"vitest": "^0.27.2"
	},
	"wireit": {
		"build": {
			"command": "svelte-package -i ./src",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": [
				"dist/**"
			]
		},
		"check": {
			"clean": "if-file-deleted",
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": []
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"publint"
			],
			"files": [
				"dist/**",
				"!**/*.test.*",
				"!**/*.spec.*",
				"LICENSE",
				"README.md"
			],
			"output": [
				"hine*.tgz"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"build"
			],
			"files": [
				"dist/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"test",
				"build"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	}
}
