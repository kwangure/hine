{
	"name": "@hine-examples/basic",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "wireit",
		"pre-commit": "wireit"
	},
	"wireit": {
		"check": {
			"command": "tsc",
			"files": [
				"**/*.{js,ts}",
				"tsconfig.json"
			],
