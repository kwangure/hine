{
	"name": "parserer",
	"version": "0.0.3",
	"description": "A Svelte parser",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"command": "tsc",
			"dependencies": [
				"../hine:build"
			],
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": [
				"types/**"
			]
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"build",
				"publint"
			],
			"files": [
				"src/**",
				"types/**",
				"LICENSE",
				"package.json",
				"README.md"
			],
			"output": [
				"*.tgz"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"build"
			],
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"build",
				"test"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"dependencies": {
		"hine": "^0.0.12"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.0.2",
		"publint": "^0.1.11",
		"vitest": "^0.32.2"
	},
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"files": [
		"src",
		"types"
	]
}
