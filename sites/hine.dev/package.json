{
	"name": "hine.dev",
	"version": "0.0.5",
	"private": true,
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"preview": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"dependencies": [
				"../../packages/hine:build"
			],
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"build/**"
			]
		},
		"check": {
			"command": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"../../packages/hine:build"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check"
			]
		},
		"preview": {
			"command": "vite preview",
			"dependencies": [
				"build"
			],
			"files": [],
			"output": []
		},
		"test": {
			"command": "vitest run",
			"files": [
				"{src,tests}/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": []
		}
	},
	"dependencies": {
		"@hine/assets": "workspace:^",
		"@mdi/js": "^7.2.96",
		"@melt-ui/svelte": "^0.61.1",
		"@svelte-thing/components": "^0.0.9",
		"hine": "workspace:*",
		"simple-icons": "^9.9.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-vercel": "^4.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/node": "^20.10.4",
		"autoprefixer": "^10.4.14",
		"content-thing": "^0.0.12",
		"postcss": "^8.4.27",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"ts-morph": "^21.0.1",
		"typescript": "^5.1.6",
		"vite": "^5.0.9",
		"vitest": "^1.0.4",
		"wireit": "^0.14.1"
	},
	"#comment": [
		"Rollup optional dependency fixes Vercel missng module error.",
		"It might need manual synncing with Vite's version of Rollup"
	],
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "4.9.5"
	},
	"license": "MIT",
	"type": "module"
}
