{
	"name": "hine.dev",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"build/**"
			]
		},
		"check": {
			"command": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"../../packages/hine:package"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"{src,tests}/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": []
		}
	},
	"devDependencies": {
		"@hinejs/content-thing": "^0.0.0",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-vercel": "^3.0.3",
		"@sveltejs/kit": "^1.22.4",
		"autoprefixer": "^10.4.14",
		"husky": "^8.0.3",
		"postcss": "^8.4.27",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"typescript": "^5.0.0",
		"vite": "^4.4.2",
		"vitest": "^0.33.0",
		"wireit": "^0.9.3"
	},
	"type": "module",
	"dependencies": {
		"@fig/lezer-bash": "^1.2.5",
		"@hinejs/svelte-ui": "^0.0.0",
		"@lezer/cpp": "^1.0.0",
		"@lezer/css": "^1.0.1",
		"@lezer/highlight": "^1.1.2",
		"@lezer/html": "^1.0.1",
		"@lezer/javascript": "^1.0.2",
		"@lezer/json": "^1.0.0",
		"@lezer/python": "^1.1.1",
		"@lezer/rust": "^1.0.0",
		"@mdi/js": "^7.2.96",
		"@replit/codemirror-lang-svelte": "^6.0.0",
		"simple-icons": "^9.9.0"
	}
}
