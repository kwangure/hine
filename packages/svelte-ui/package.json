{
	"name": "@hinejs/svelte-ui",
	"version": "0.0.0",
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"package": "wireit",
		"publint": "wireit",
		"sync": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"./svelte-kit/output",
				"build"
			]
		},
		"check": {
			"command": "svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"sync"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"package"
			],
			"files": [
				"dist/**",
				"LICENSE",
				"README.md"
			],
			"output": [
				"*.tgz"
			]
		},
		"package": {
			"clean": "if-file-deleted",
			"command": "svelte-package",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"svelte.config.js",
				"tsconfig.json"
			],
			"output": [
				"dist"
			]
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"publint",
				"sync"
			]
		},
		"publint": {
			"command": "publint",
			"files": [
				"dist",
				"package.json"
			],
			"output": []
		},
		"sync": {
			"command": "svelte-kit sync",
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js",
				"tsconfig.json"
			],
			"output": []
		},
		"typegen": {
			"command": "tsc --project tsconfig.build.json",
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": [
				"dist/**/*.d.ts"
			]
		}
	},
	"exports": {
		"./components": {
			"svelte": "./dist/components/index.js",
			"default": "./dist/components/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"@sveltejs/kit": "^1.20.4",
		"svelte": "^4.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/kit": "^1.20.4",
		"@sveltejs/package": "^2.0.0",
		"autoprefixer": "^10.4.14",
		"postcss": "^8.4.27",
		"publint": "^0.1.9",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.4.2"
	},
	"type": "module"
}
