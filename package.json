{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"prepare": "husky install",
		"test": "wireit",
		"version": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"@kwangure/eslint-config-svelte": "^0.3.4",
		"eslint": "^8.32.0",
		"husky": "^8.0.3",
		"prettier": "^2.8.8",
		"wireit": "^0.9.3"
	},
	"wireit": {
		"dev": {
			"dependencies": [
				"./packages/playground:dev"
			]
		},
		"format": {
			"command": "prettier --plugin-search-dir . --write .",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!**/dist/**",
				".eslintignore",
				".eslintrc.cjs"
			],
			"output": []
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				"!**/dist/**",
				".eslintignore",
				".eslintrc.cjs"
			],
			"output": []
		},
		"pack": {
			"dependencies": [
				"./packages/hine:pack"
			]
		},
		"pre-commit": {
			"dependencies": [
				"lint",
				"./packages/hine:pre-commit"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test"
			]
		},
		"version": {
			"#comment": [
				"Changesets doesn't bump package-lock.json so we run `npm install`",
				"to do it for us"
			],
			"command": "changeset version && npm install",
			"files": [
				"./changeset/*.md",
				"./packages/**/package.json",
				"./packages/**/CHANGELOG.md"
			]
		}
	}
}
