{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"declarationDir": "types",
		"emitDeclarationOnly": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"$types": ["./src/types.ts"]
		},
		"resolveJsonModule": true,
		"strict": true,
		"target": "esnext"
	},
	"include": ["src", "tests"]
}
