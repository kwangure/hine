{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "wireit",
		"pre-commit": "wireit",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"@kwangure/eslint-config-svelte": "^0.2.9",
		"eslint": "^8.32.0",
		"husky": "^8.0.3",
		"wireit": "^0.9.3"
	},
	"wireit": {
		"lint": {
            "command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
            "files": [
                "**/*.{js,svelte}",
                ".eslintignore",
                ".eslintrc.cjs"
            ],
            "output": []
        },
		"pre-commit": {
            "dependencies": [
				"lint",
                "./packages/hine:pre-commit"
            ]
        }
	}
}
