{
	"name": "hine-next",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"clean": "if-file-deleted",
			"command": "tsc",
			"dependencies": [
				"../hine:build",
				"../parserer:build"
			],
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": [
				"types/**"
			]
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"publint"
			],
			"files": [
				"src/**",
				"types/**",
				"LICENSE",
				"package.json",
				"README.md"
			],
			"output": [
				"*.tgz"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"build"
			],
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"build",
				"test"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"dependencies": {
		"parserer": "^0.0.4"
	},
	"devDependencies": {
		"publint": "^0.1.12",
		"typescript": "^5.1.5",
		"vitest": "^0.32.2"
	},
	"exports": {
		"./codegen": {
			"types": "./types/codegen/codegen.d.ts",
			"default": "./src/codegen/codegen.js"
		},
		"./processor": {
			"types": "./types/processor/index.d.ts",
			"default": "./src/processor/index.js"
		}
	},
	"files": [
		"src",
		"types"
	]
}
