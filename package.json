{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*",
		"sites/*"
	],
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"package": "wireit",
		"pre-commit": "wireit",
		"prepare": "husky install",
		"release": "wireit",
		"test": "wireit",
		"version": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"husky": "^8.0.3",
		"remark-parse": "^10.0.2",
		"remark-stringify": "^10.0.3",
		"unified": "^10.1.2",
		"unist-util-visit": "^4.0.0",
		"wireit": "^0.13.0"
	},
	"wireit": {
		"build": {
			"dependencies": [
				"./packages/svelte-ui:build",
				"./sites/hine.dev:build",
				"build:readme"
			]
		},
		"build:readme": {
			"clean": false,
			"command": "node ./scripts/build-readme.js",
			"files": [
				"README_TEMPLATE.md",
				"examples/**/*.js"
			],
			"output": [
				"README.md"
			]
		},
		"check": {
			"dependencies": [
				"./examples/basic:check",
				"./packages/hine:check",
				"./packages/svelte-ui:check",
				"./sites/hine.dev:check"
			]
		},
		"dev": {
			"dependencies": [
				"./sites/hine.dev:dev"
			]
		},
		"format": {
			"dependencies": [
				"./examples/basic:format",
				"./packages/eslint-config:format",
				"./packages/hine:format",
				"./packages/prettier-config:format",
				"./packages/svelte-ui:format",
				"./sites/hine.dev:format"
			]
		},
		"lint": {
			"dependencies": [
				"./examples/basic:lint",
				"./packages/eslint-config:lint",
				"./packages/hine:lint",
				"./packages/prettier-config:lint",
				"./packages/svelte-ui:lint",
				"./sites/hine.dev:lint"
			]
		},
		"package": {
			"dependencies": [
				"./packages/eslint-config:package",
				"./packages/hine:package",
				"./packages/svelte-ui:package",
				"./packages/prettier-config:package"
			]
		},
		"pre-commit": {
			"dependencies": [
				"build:readme",
				"./examples/basic:pre-commit",
				"./packages/eslint-config:pre-commit",
				"./packages/hine:pre-commit",
				"./packages/prettier-config:pre-commit",
				"./packages/svelte-ui:pre-commit",
				"./sites/hine.dev:pre-commit"
			]
		},
		"release": {
			"command": "npx changeset publish",
			"dependencies": [
				"./packages/hine:release"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test"
			]
		},
		"version": {
			"#comment": [
				"Changesets doesn't bump package-lock.json so we run `npm install`",
				"to do it for us"
			],
			"command": "changeset version && npm install",
			"files": [
				"./changeset/*.md",
				"./packages/**/package.json",
				"./packages/**/CHANGELOG.md"
			]
		}
	}
}
