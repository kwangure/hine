{
	"name": "hine",
	"version": "0.0.17",
	"description": "A state machine library",
	"scripts": {
		"format": "wireit",
		"lint": "wireit",
		"package": "wireit",
		"pre-commit": "wireit",
		"publint": "wireit",
		"release": "wireit",
		"test": "wireit"
	},
	"keywords": [
		"state",
		"machine",
		"state-machine",
		"svelte",
		"react"
	],
	"files": [
		"src",
		"types",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"wireit": {
		"check": {
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": []
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!types/**",
				".prettierignore"
			],
			"output": []
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				".eslintignore",
				"eslint.config.js"
			],
			"output": []
		},
		"package": {
			"command": "tsc --project tsconfig.build.json",
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.build.json",
				"tsconfig.json"
			],
			"output": [
				"types"
			]
		},
		"publint": {
			"command": "publint",
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"format",
				"lint",
				"publint",
				"test"
			]
		},
		"release": {
			"dependencies": [
				"package",
				"publint",
				"test"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"devDependencies": {
		"@hinejs/eslint-config": "*",
		"@hinejs/prettier-config": "*",
		"eslint": "^8.47.0",
		"prettier": "^3.0.2",
		"publint": "^0.1.11",
		"typescript": "^5.1.6",
		"vite": "^4.4.8",
		"vitest": "^0.27.3"
	},
	"prettier": "@hinejs/prettier-config",
	"license": "MIT",
	"type": "module"
}
