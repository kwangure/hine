{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*",
		"packages/hine-next/playground"
	],
	"scripts": {
		"dev": "wireit",
		"lint": "wireit",
		"pre-commit": "wireit",
		"prepare": "husky install",
		"test": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"@kwangure/eslint-config-svelte": "^0.2.9",
		"eslint": "^8.32.0",
		"husky": "^8.0.3",
		"wireit": "^0.9.3"
	},
	"wireit": {
		"dev": {
			"dependencies": [
				"./packages/hine-next/playground:dev"
			]
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				"!**/dist/**",
				".eslintignore",
				".eslintrc.cjs"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"lint",
				"./packages/hine:pre-commit"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test"
			]
		}
	}
}
