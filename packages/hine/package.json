{
	"name": "hine",
	"version": "0.0.21",
	"description": "A state machine library",
	"scripts": {
		"build": "wireit",
		"pre-commit": "wireit",
		"publint": "wireit",
		"release": "wireit",
		"test": "wireit"
	},
	"keywords": [
		"state",
		"machine",
		"state-machine",
		"svelte",
		"react"
	],
	"files": [
		"src",
		"types",
		"docs",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./types/exports.d.ts",
			"default": "./src/index.js"
		}
	},
	"wireit": {
		"build": {
			"command": "tsc -b",
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": [
				"types"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"build"
			],
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"build",
				"publint",
				"test"
			]
		},
		"release": {
			"dependencies": [
				"build",
				"publint",
				"test"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"devDependencies": {
		"publint": "^0.2.2",
		"typescript": "^5.1.6",
		"vite": "^4.4.8",
		"vitest": "^0.33.0"
	},
	"license": "MIT",
	"type": "module"
}
