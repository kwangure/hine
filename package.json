{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*",
		"sites/*"
	],
	"#comment": [
		"Prefix Husky with 'npx' to stop failing Vercel deploy"
	],
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"package": "wireit",
		"pre-commit": "wireit",
		"prepare": "npx husky install",
		"release": "wireit",
		"test": "wireit",
		"version": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"@kwangure/eslint-config-svelte": "^0.3.6",
		"eslint": "^8.32.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"husky": "^8.0.3",
		"remark-parse": "^10.0.2",
		"remark-stringify": "^10.0.3",
		"unified": "^10.1.2",
		"unist-util-visit": "^5.0.0",
		"wireit": "^0.9.3"
	},
	"wireit": {
		"build": {
			"dependencies": [
				"./packages/svelte-ui:build",
				"./sites/hine.dev:build",
				"build:readme"
			]
		},
		"build:readme": {
			"clean": false,
			"command": "node ./scripts/build-readme.js",
			"files": [
				"README_TEMPLATE.md",
				"examples/**/*.js"
			],
			"output": [
				"README.md"
			]
		},
		"check": {
			"dependencies": [
				"./examples/basic:check",
				"./packages/content-thing:check",
				"./packages/hine:check",
				"./packages/remark-attributes:check",
				"./packages/remark-toc:check",
				"./packages/svelte-ui:check",
				"./sites/hine.dev:check"
			]
		},
		"dev": {
			"dependencies": [
				"./sites/hine.dev:dev"
			]
		},
		"format": {
			"dependencies": [
				"./examples/basic:format",
				"./packages/content-thing:format",
				"./packages/hine:format",
				"./packages/internal-utils:format",
				"./packages/prettier:format",
				"./packages/remark-attributes:format",
				"./packages/remark-toc:format",
				"./packages/remark-variables:format",
				"./packages/remark-yaml-parse:format",
				"./packages/svelte-ui:format",
				"./sites/hine.dev:format"
			]
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				"!**/dist/**",
				"!**/tests/samples/**",
				".eslintignore",
				".eslintrc.cjs"
			],
			"output": []
		},
		"package": {
			"dependencies": [
				"./packages/content-thing:package",
				"./packages/hine:package",
				"./packages/svelte-ui:package",
				"./packages/internal-utils:package",
				"./packages/prettier:package",
				"./packages/remark-attributes:package",
				"./packages/remark-toc:package",
				"./packages/remark-variables:package",
				"./packages/remark-yaml-parse:package"
			]
		},
		"pre-commit": {
			"dependencies": [
				"lint",
				"build:readme",
				"./examples/basic:pre-commit",
				"./packages/content-thing:pre-commit",
				"./packages/hine:pre-commit",
				"./packages/svelte-ui:pre-commit",
				"./packages/remark-attributes:pre-commit",
				"./packages/remark-toc:pre-commit",
				"./packages/remark-yaml-parse:pre-commit",
				"./sites/hine.dev:pre-commit"
			]
		},
		"release": {
			"command": "npx changeset publish",
			"dependencies": [
				"./packages/hine:release"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test",
				"./packages/internal-utils:test",
				"./packages/remark-attributes:test",
				"./packages/remark-variables:test",
				"./packages/remark-yaml-parse:test"
			]
		},
		"version": {
			"#comment": [
				"Changesets doesn't bump package-lock.json so we run `npm install`",
				"to do it for us"
			],
			"command": "changeset version && npm install",
			"files": [
				"./changeset/*.md",
				"./packages/**/package.json",
				"./packages/**/CHANGELOG.md"
			]
		}
	}
}
