{
	"name": "@hinejs/vite-plugin-markdown",
	"version": "0.0.0",
	"scripts": {
		"check": "wireit",
		"package": "wireit"
	},
	"wireit": {
		"check": {
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": []
		},
		"package": {
			"clean": "if-file-deleted",
			"command": "tsc --project tsconfig.build.json",
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.build.json",
				"tsconfig.json"
			],
			"output": [
				"types"
			]
		},
		"pre-commit": {
			"dependencies": [
				"check"
			]
		}
	},
	"license": "MIT",
	"files": [
		"src",
		"types",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"devDependencies": {
		"@types/dlv": "^1.1.2",
		"@types/js-yaml": "^4.0.5",
		"type-fest": "^4.1.0",
		"vite": "^4.4.8"
	},
	"type": "module",
	"dependencies": {
		"@rollup/pluginutils": "^5.0.2",
		"@types/mdast": "^4.0.0",
		"dlv": "^1.1.3",
		"js-yaml": "^4.1.0",
		"md-attr-parser": "^1.3.0",
		"remark-frontmatter": "^4.0.1",
		"remark-parse": "^10.0.2",
		"unified": "^10.1.2",
		"unist-util-visit": "^5.0.0"
	}
}
