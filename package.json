{
	"name": "hine-monorepo",
	"preview": false,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*",
		"sites/*"
	],
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"prepare": "husky install",
		"release": "wireit",
		"test": "wireit",
		"version": "wireit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.26.1",
		"@kwangure/eslint-config-svelte": "^0.3.6",
		"eslint": "^8.32.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"husky": "^8.0.3",
		"prettier": "^2.8.8",
		"prettier-plugin-svelte": "^2.10.1",
		"remark-parse": "^10.0.2",
		"remark-stringify": "^10.0.3",
		"unified": "^10.1.2",
		"unist-util-visit": "^5.0.0",
		"wireit": "^0.9.3"
	},
	"wireit": {
		"build": {
			"dependencies": [
				"./packages/hine:build",
				"build:readme"
			]
		},
		"build:readme": {
			"clean": false,
			"command": "node ./scripts/build-readme.js",
			"files": [
				"README_TEMPLATE.md",
				"examples/**/*.js"
			],
			"output": [
				"README.md"
			]
		},
		"check": {
			"dependencies": [
				"./packages/hine:check",
				"./examples/basic:check"
			]
		},
		"dev": {
			"dependencies": [
				"./sites/hine.dev:dev"
			]
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!**/dist/**",
				"!**/tests/samples/**",
				".prettierignore",
				".prettierrc"
			],
			"output": []
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				"!**/dist/**",
				"!**/tests/samples/**",
				".eslintignore",
				".eslintrc.cjs"
			],
			"output": []
		},
		"pack": {
			"dependencies": [
				"./packages/hine:pack"
			]
		},
		"pre-commit": {
			"dependencies": [
				"format",
				"lint",
				"build:readme",
				"./packages/hine:pre-commit",
				"./examples/basic:pre-commit"
			]
		},
		"release": {
			"command": "npx changeset publish",
			"dependencies": [
				"./packages/hine:release"
			]
		},
		"test": {
			"dependencies": [
				"./packages/hine:test"
			]
		},
		"version": {
			"#comment": [
				"Changesets doesn't bump package-lock.json so we run `npm install`",
				"to do it for us"
			],
			"command": "changeset version && npm install",
			"files": [
				"./changeset/*.md",
				"./packages/**/package.json",
				"./packages/**/CHANGELOG.md"
			]
		}
	}
}
