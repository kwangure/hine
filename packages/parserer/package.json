{
	"name": "parserer",
	"version": "0.0.3",
	"description": "A Svelte parser",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"check": "wireit",
		"pack": "wireit",
		"pre-commit": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"check": {
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": []
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"publint"
			],
			"files": [
				"dist/**",
				"!**/*.test.*",
				"!**/*.spec.*",
				"LICENSE",
				"README.md"
			],
			"output": [
				"parserer*.tgz"
			]
		},
		"package": {
			"command": "svelte-package -i ./src",
			"files": [
				"src/**/*.{js,ts,svelte}"
			],
			"output": [
				"dist/**"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"package"
			],
			"files": [
				"dist/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"test",
				"package"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"dependencies": {
		"hine": "^0.0.12"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.0.2",
		"publint": "^0.1.11",
		"vitest": "^0.32.2"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!**/*.test.*",
		"!**/*.spec.*"
	]
}
