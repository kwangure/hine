{
	"name": "@hinejs/content-thing",
	"version": "0.0.0",
	"scripts": {
		"check": "wireit",
		"format": "wireit",
		"lint": "wireit",
		"package": "wireit"
	},
	"wireit": {
		"check": {
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"dependencies": [
				"../internal-utils:package",
				"../remark-attributes:package",
				"../remark-toc:package",
				"../remark-variables:package",
				"../remark-yaml-parse:package"
			],
			"output": []
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!types/**",
				".prettierignore"
			],
			"output": []
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				".eslintignore",
				"eslint.config.js"
			],
			"output": []
		},
		"package": {
			"command": "tsc --project tsconfig.build.json",
			"dependencies": [
				"../internal-utils:package",
				"../remark-attributes:package",
				"../remark-toc:package",
				"../remark-variables:package",
				"../remark-yaml-parse:package"
			],
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.build.json",
				"tsconfig.json"
			],
			"output": [
				"types"
			]
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"format",
				"publint"
			]
		},
		"publint": {
			"command": "publint",
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		}
	},
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"dependencies": {
		"@hinejs/internal-utils": "^0.0.0",
		"@hinejs/remark-attributes": "*",
		"@hinejs/remark-toc": "*",
		"@hinejs/remark-variables": "*",
		"@hinejs/remark-yaml-parse": "*",
		"@rollup/pluginutils": "^5.0.3",
		"js-yaml": "^4.1.0",
		"remark-stringify": "^10.0.3",
		"vfile": "^5.0.0"
	},
	"devDependencies": {
		"@hinejs/eslint-config": "*",
		"@hinejs/prettier-config": "*",
		"@types/mdast": "^4.0.0",
		"@types/node": "^20.4.10",
		"eslint": "^8.47.0",
		"prettier": "^3.0.2",
		"publint": "^0.1.16",
		"typescript": "^5.1.6",
		"vite": "^4.4.9"
	},
	"files": [
		"src",
		"types",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"prettier": "@hinejs/prettier-config",
	"license": "MIT",
	"type": "module"
}
