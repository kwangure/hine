{
	"name": "hine.dev",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"format": "wireit",
		"lint": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"dependencies": [
				"../../packages/hine:package",
				"../../packages/svelte-ui:package"
			],
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"build/**"
			]
		},
		"check": {
			"command": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"../../packages/hine:package",
				"../../packages/svelte-ui:package"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!types/**",
				"!dist/**",
				"!.svelte-kit/**",
				".prettierignore",
				"prettier.config.js"
			],
			"output": []
		},
		"lint": {
			"command": "eslint \"**/*.{js,svelte}\" --color --cache --fix",
			"files": [
				"**/*.{js,svelte}",
				".eslintignore",
				"eslint.config.js"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"format",
				"lint"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"{src,tests}/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": []
		}
	},
	"dependencies": {
		"@mdi/js": "^7.2.96",
		"hine": "workspace:^0.0.19",
		"simple-icons": "^9.9.0",
		"svelte-ui": "workspace:^0.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-vercel": "^3.0.3",
		"@sveltejs/kit": "^1.22.4",
		"@types/eslint": "^8.44.2",
		"autoprefixer": "^10.4.14",
		"content-thing": "^0.0.6",
		"eslint": "^8.47.0",
		"eslint-config": "workspace:*",
		"husky": "^8.0.3",
		"postcss": "^8.4.27",
		"prettier": "^3.0.2",
		"prettier-config": "workspace:*",
		"prettier-plugin-svelte": "^3.0.3",
		"prettier-plugin-tailwindcss": "^0.5.3",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"typescript": "^5.1.6",
		"vite": "^4.4.2",
		"vitest": "^0.33.0",
		"wireit": "^0.13.0"
	},
	"license": "MIT",
	"type": "module"
}
