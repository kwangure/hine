{
	"name": "hine.dev",
	"version": "0.0.4",
	"private": true,
	"scripts": {
		"build": "wireit",
		"check": "wireit",
		"dev": "vite dev",
		"preview": "wireit",
		"test": "wireit"
	},
	"wireit": {
		"build": {
			"command": "vite build",
			"dependencies": [
				"../../packages/hine:build"
			],
			"files": [
				"src/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": [
				"build/**"
			]
		},
		"check": {
			"command": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
			"dependencies": [
				"../../packages/hine:build"
			],
			"files": [
				"{src,test}/**/*.{js,ts,svelte}",
				"tsconfig.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check"
			]
		},
		"preview": {
			"command": "vite preview",
			"dependencies": [
				"build"
			],
			"files": [],
			"output": []
		},
		"test": {
			"command": "vitest run",
			"files": [
				"{src,tests}/**/*.{js,ts,svelte}",
				"static/**",
				"svelte.config.js",
				"vite.config.js"
			],
			"output": []
		}
	},
	"dependencies": {
		"@hine/assets": "workspace:^",
		"@mdi/js": "^7.2.96",
		"@melt-ui/svelte": "^0.61.1",
		"@svelte-thing/components": "^0.0.6",
		"hine": "workspace:*",
		"simple-icons": "^9.9.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-vercel": "^3.0.3",
		"@sveltejs/kit": "^1.22.4",
		"autoprefixer": "^10.4.14",
		"content-thing": "^0.0.10",
		"postcss": "^8.4.27",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.3",
		"ts-morph": "^21.0.1",
		"typescript": "^5.1.6",
		"vite": "^4.4.2",
		"vitest": "^0.33.0",
		"wireit": "^0.13.0"
	},
	"license": "MIT",
	"type": "module"
}
