{
	"name": "hine",
	"version": "0.0.17",
	"description": "A state machine library",
	"scripts": {
		"build": "wireit",
		"format": "wireit",
		"pack": "wireit",
		"package": "npm run build",
		"pre-commit": "wireit",
		"publint": "wireit",
		"release": "wireit",
		"test": "wireit"
	},
	"keywords": [
		"state",
		"machine",
		"state-machine",
		"svelte",
		"react"
	],
	"files": [
		"src",
		"types",
		"!**/*.test.*",
		"!**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.js"
		}
	},
	"wireit": {
		"build": {
			"clean": "if-file-deleted",
			"command": "tsc --project tsconfig.build.json",
			"files": [
				"src/**/*.{js,ts}",
				"tsconfig.build.json",
				"tsconfig.json"
			],
			"output": [
				"types"
			]
		},
		"check": {
			"command": "tsc",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}",
				"tsconfig.json"
			],
			"output": []
		},
		"format": {
			"command": "prettier . --write --cache",
			"files": [
				"**/*.{css,html,js,json,md,ts,svelte}",
				"!types/**",
				".prettierignore"
			],
			"output": []
		},
		"pack": {
			"command": "npm pack",
			"dependencies": [
				"build",
				"publint"
			],
			"files": [
				"src/**",
				"types/**",
				"!**/*.test.*",
				"!**/*.spec.*",
				"LICENSE",
				"README.md"
			],
			"output": [
				"hine*.tgz"
			]
		},
		"publint": {
			"command": "publint",
			"dependencies": [
				"build"
			],
			"files": [
				"src/**",
				"types/**",
				"package.json"
			],
			"output": []
		},
		"pre-commit": {
			"dependencies": [
				"check",
				"format",
				"test"
			]
		},
		"release": {
			"dependencies": [
				"build",
				"publint",
				"test"
			]
		},
		"test": {
			"command": "vitest run",
			"files": [
				"src/**/*.{js,ts}",
				"tests/**/*.{js,ts}"
			],
			"output": []
		}
	},
	"devDependencies": {
		"@hinejs/prettier": "*",
		"prettier": "^3.0.2",
		"publint": "^0.1.11",
		"typescript": "^5.0.3",
		"vite": "^4.4.8",
		"vitest": "^0.27.3"
	},
	"prettier": "@hinejs/prettier",
	"license": "MIT",
	"type": "module"
}
